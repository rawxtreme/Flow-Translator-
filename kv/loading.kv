# =============================================
#   Loading Screen KV - Progress Animation
# =============================================

<LoadingScreen>:
    canvas.before:
        Color:
            rgba: 0.02, 0.02, 0.08, 1
        Rectangle:
            pos: self.pos
            size: self.size
        Color:
            rgba: 0.06, 0.02, 0.14, 0.8
        Rectangle:
            pos: self.pos
            size: self.width, self.height * 0.4

    FloatLayout:
        opacity: root.content_opacity

        # ---- LOGO ----
        Image:
            source: 'assets/images/logo.png'
            pos_hint: {'center_x': 0.5, 'center_y': 0.65}
            size_hint: None, None
            size: 90, 90
            allow_stretch: True
            keep_ratio: True

        # ---- WELCOME TEXT ----
        Label:
            text: 'Welcome to Translation App'
            pos_hint: {'center_x': 0.5, 'center_y': 0.50}
            size_hint: None, None
            size: self.texture_size
            font_size: '22sp'
            bold: True
            color: 0.95, 0.95, 1.0, 1

        Label:
            text: 'Made by Aaditya Shukla'
            pos_hint: {'center_x': 0.5, 'center_y': 0.44}
            size_hint: None, None
            size: self.texture_size
            font_size: '13sp'
            color: 0.29, 0.56, 1.0, 1

        # ---- PROGRESS BAR CONTAINER ----
        Widget:
            pos_hint: {'center_x': 0.5, 'center_y': 0.32}
            size_hint: None, None
            size: 280, 6
            canvas:
                # Track
                Color:
                    rgba: 0.15, 0.15, 0.30, 1
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [3]
                # Fill
                Color:
                    rgba: 0.29, 0.56, 1.0, 1
                RoundedRectangle:
                    pos: self.pos
                    size: self.width * (root.progress / 100), self.height
                    radius: [3]
                # Glow on fill end
                Color:
                    rgba: 0.52, 0.24, 1.0, 0.8
                Ellipse:
                    pos: self.x + self.width * (root.progress / 100) - 4, self.y - 4
                    size: 14, 14

        # ---- PROGRESS PERCENTAGE ----
        Label:
            text: f'{int(root.progress)}%'
            pos_hint: {'center_x': 0.5, 'center_y': 0.265}
            size_hint: None, None
            size: self.texture_size
            font_size: '12sp'
            color: 0.52, 0.24, 1.0, 1

        # ---- LOADING MESSAGE ----
        Label:
            text: root.loading_text + root.dots_text
            pos_hint: {'center_x': 0.5, 'center_y': 0.20}
            size_hint: None, None
            size: self.texture_size
            font_size: '13sp'
            color: 0.65, 0.65, 0.85, 1

        # ---- BOTTOM VERSION ----
        Label:
            text: 'v1.0.0'
            pos_hint: {'center_x': 0.5, 'center_y': 0.07}
            size_hint: None, None
            size: self.texture_size
            font_size: '11sp'
            color: 0.35, 0.35, 0.50, 1
